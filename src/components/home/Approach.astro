---
import { Image } from "astro:assets";
import approachImage from "@assets/img/home/placasSolares.jpg";
import iconAnalysis from "@assets/svg/home/Scan_alt.svg";
import iconCommitment from "@assets/svg/home/lightning.svg";
import iconInvestment from "@assets/svg/home/Line_up.svg";

interface ApproachCard {
  title: string;
  description: string;
  alt: string;
}

interface Props {
  titleLines: string[];
  imageAlt: string;
  cards: ApproachCard[];
}

const { titleLines, imageAlt, cards } = Astro.props;
const icons = [iconAnalysis, iconCommitment, iconInvestment];
---

<section class="relative text-white">
  <div class="absolute inset-0">
    <Image
      src={approachImage}
      alt={imageAlt}
      class="h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-black/40"></div>
  </div>
  <div class="relative container mx-auto px-4 py-16">
    <div class="grid gap-8 lg:grid-cols-[1fr_2fr] lg:items-center">
      <h2 class="text-2xl font-semibold lg:text-4xl">
        {
          titleLines.map((line, index) => (
            <>
              {line}
              {index < titleLines.length - 1 && <br />}
            </>
          ))
        }
      </h2>
      <div class="grid gap-6 md:grid-cols-3">
        {
          cards.map((card, index) => (
            <div class="flex flex-col items-center lg:items-start gap-3">
              <div class="rounded-lg bg-primary p-3">
                <Image
                  src={icons[index]}
                  alt={card.alt}
                  class="size-8 lg:size-12"
                />
              </div>
              <h3 class="text-base lg:text-lg font-semibold">{card.title}</h3>
              <p class="text-center lg:text-left text-base lg:text-lg text-white/90">
                {card.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
