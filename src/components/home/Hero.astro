---
import { Image } from "astro:assets";
import heroImage from "@assets/img/home/bgBannerHome.jpg";

interface Props {
  title: string;
  subtitle: string;
  imageAlt: string;
}

const { title, subtitle, imageAlt } = Astro.props;
---

<section class="relative text-white">
  <div class="absolute inset-0">
    <Image src={heroImage} alt={imageAlt} class="h-full w-full object-cover" />
    <div class="absolute inset-0 bg-black/50"></div>
  </div>
  <div
    class="relative container mx-auto px-4 text-center flex flex-col items-center justify-center min-h-[80vh]"
  >
    <h1
      class="text-3xl font-bold leading-none text-primary lg:text-5xl xl:text-6xl max-w-4xl"
    >
      {title}
    </h1>
    <p class="mt-4 text-lg lg:text-2xl">{subtitle}</p>
  </div>
</section>
