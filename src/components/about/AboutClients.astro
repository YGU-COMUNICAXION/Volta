---
import { Image } from "astro:assets";

interface Segment {
  title: string;
  description: string;
  icon: ImageMetadata;
}

interface Props {
  title: string;
  segments: Segment[];
}

const { title, segments } = Astro.props;
---

<section class="bg-white py-16 lg:py-24">
  <div class="mx-auto w-full px-6 lg:px-10">
    <h2 class="text-center text-2xl font-medium lg:text-4xl">{title}</h2>
    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-5">
      {
        segments.map((segment) => (
          <div class="flex min-h-72 flex-col items-center justify-center rounded-2xl border border-black/80 bg-white px-6 py-8 text-center shadow-[0_8px_20px_rgba(0,0,0,0.08)] lg:min-h-80">
            <Image
              src={segment.icon}
              alt=""
              class="h-24 w-24 object-contain lg:h-28 lg:w-28"
            />
            <p class="mt-10 text-xl leading-tight text-black lg:text-2xl">
              <strong>{segment.title}</strong>{" "}
              <span>{segment.description}</span>
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
