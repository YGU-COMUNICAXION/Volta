---
import { Image } from "astro:assets";

interface Company {
  name: string;
  logo: ImageMetadata;
  description: string;
  highlight: string;
  bullets: string[];
  cardImage?: ImageMetadata;
}

interface Props {
  companies: Company[];
  placeholderImage: ImageMetadata;
}

const { companies, placeholderImage } = Astro.props;
---

<section class="bg-white pb-16">
  <div class="container mx-auto px-6 py-10 lg:py-24">
    <div class="text-center">
      <h2 class="text-2xl font-medium lg:text-4xl">
        Quiénes conforman Grupo VOLTA
      </h2>
      <p
        class="mt-2 text-sm text-black/70 font-normal sm:text-base lg:text-2xl"
      >
        Regulus, Sujio, Sujio Generación y HHGM son marcas de VOLTA que brindan distintas
        soluciones en la industria energética.
      </p>
    </div>

    <div class="mt-10 grid gap-8 md:grid-cols-2 xl:grid-cols-4">
      {
        companies.map((company) => (
          <article class="overflow-hidden rounded-2xl border border-black/10 bg-white shadow-[0_18px_45px_rgba(0,0,0,0.12)]">
            <div class="relative">
              <Image
                src={company.cardImage || placeholderImage}
                alt={company.name}
                class="h-44 w-full object-cover xl:h-40"
              />
              <div
                class="absolute left-6 -bottom-8 flex size-20 border-[6px] border-white
               items-center justify-center rounded-full bg-white shadow-[0_8px_24px_rgba(0,0,0,0.14)] lg:size-24"
              >
                <Image
                  src={company.logo}
                  alt={company.name}
                  class="size-14 object-contain lg:size-16"
                />
              </div>
            </div>
            <div class="px-6 pb-6 pt-14">
              <h3 class="text-lg font-medium uppercase tracking-wide lg:text-xl">
                {company.name}
              </h3>
              <p class="mt-3 text-sm text-black/70 lg:text-base">
                {company.description}
              </p>
              <p class="mt-4 text-sm font-medium italic lg:text-base">
                {company.highlight}
              </p>
              <ul class="mt-3 list-disc space-y-2 pl-4 text-sm text-black/70 lg:text-base">
                {company.bullets.map((bullet) => (
                  <li>{bullet}</li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
