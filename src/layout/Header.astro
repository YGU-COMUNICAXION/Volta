---
import {
  Bars3Icon,
  LanguageIcon,
  XMarkIcon,
} from "@heroicons/react/24/outline";
import { Image } from "astro:assets";
import {
  getAlternateLocaleUrl,
  getPageKeyFromPathname,
  getRoute,
  routeKeys,
  type Locale,
} from "@i18n/routes";
import { ui } from "@i18n/ui";

import imgLogo from "@assets/logo.png";

interface Props {
  locale: Locale;
  pathname: string;
}

const { locale, pathname } = Astro.props;
const dictionary = ui[locale];
const activePage = getPageKeyFromPathname(pathname);
const alternateUrl = getAlternateLocaleUrl(pathname);
---

<header
  id="header"
  data-scrolled="false"
  class:list={[
    "group/header flex items-center justify-center",
    "z-20 fixed w-full left-0 right-0 transition-colors duration-300",
    "bg-white",
  ]}
>
  <div
    class="container relative flex items-center justify-between gap-4 px-4 md:py-0 lg:p-0 md:px-0"
  >
    <div class="absolute lg:hidden">
      <Bars3Icon
        id="menu-icon"
        data-header-icon
        className={`size-8 lg:hidden transition-colors duration-300`}
      />
      <XMarkIcon
        id="close-icon"
        data-header-icon
        className={`hidden size-8 lg:hidden transition-colors duration-300`}
      />
    </div>

    <div class="flex w-full items-center justify-center lg:w-auto lg:justify-start">
      <a
        href={getRoute(locale, "home")}
        data-header-brand
        class="flex items-center transition-colors duration-300"
      >
        <Image
          class="h-16 w-auto lg:h-24"
          src={imgLogo}
          alt={dictionary.header.logoAlt}
        />
      </a>
    </div>

    <nav
      id="navigator-menu"
      class:list={[
        "bg-white fixed -top-full left-0 right-0 lg:top-0 lg:left-auto lg:right-auto",
        "flex flex-col items-center justify-center shadow lg:shadow-none p-6 py-8 lg:p-0 lg:py-0",
        "transition-[top] duration-300 ease-in-out lg:transition-none",
        "lg:static lg:flex-1 lg:flex lg:items-center lg:gap-4 lg:pt-1 lg:bg-transparent",
      ]}
    >
      <ul
        data-header-nav
        class={`h-full container
        flex flex-col lg:flex-row items-center justify-end gap-8 lg:gap-14
        lg:[&>li]:text-center
        [&>li>a]:relative [&>li>a]:uppercase [&>li]:inline-block
        [&>li>a]:hover:underline [&>li>a]:transition-colors [&>li>a]:duration-300
        [&>li>a]:ease-in-out
        font-normal text-base lg:text-lg xl:text-xl transition-colors duration-300
      `}
      >
        {
          routeKeys.map((key) => (
            <li>
              <a
                href={getRoute(locale, key)}
                class:list={[key === activePage && "active"]}
              >
                {dictionary.header.nav[key]}
              </a>
            </li>
          ))
        }
        <li class="lg:hidden">
          <a
            href={alternateUrl}
            aria-label={dictionary.header.switchLabel}
            class="inline-flex items-center gap-2 rounded-full border border-black/20 px-4 py-2"
          >
            <LanguageIcon className="size-5" />
            <span>{dictionary.header.switchText}</span>
          </a>
        </li>
      </ul>
    </nav>

    <!-- <a
      href={alternateUrl}
      aria-label={dictionary.header.switchLabel}
      class="absolute right-0 inline-flex items-center justify-center rounded-full p-2 text-black transition hover:text-primary lg:static"
    >
      <LanguageIcon className="size-6 lg:size-7" />
      <span class="sr-only">{dictionary.header.switchText}</span>
    </a> -->
  </div>
</header>

<style>
  @reference "../styles/global.css";

  #navigator-menu a:is(.active) {
    font-weight: 600;
  }

  .header-logo {
    @apply h-8 md:h-12 w-auto;
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const barsIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");
    const navigatorMenu = document.querySelector("#navigator-menu");
    const header = document.querySelector<HTMLElement>("#header");

    if (!navigatorMenu || !barsIcon || !closeIcon || !header) {
      throw new Error("Element not found");
    }

    const setMenuOpen = (open: boolean | undefined) => {
      barsIcon.classList.toggle("hidden", open);
      closeIcon.classList.toggle("hidden", !open);
      navigatorMenu.classList.toggle("top-16", open);
      header.setAttribute("data-menu-open", open ? "true" : "false");
    };

    barsIcon.addEventListener("click", () => setMenuOpen(true));
    closeIcon.addEventListener("click", () => setMenuOpen(false));
  });
</script>
