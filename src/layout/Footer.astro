---
import { Image } from "astro:assets";
import { getRoute, routeKeys, type Locale } from "@i18n/routes";
import { ui } from "@i18n/ui";
import logo from "@assets/logo_alt.png";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dictionary = ui[locale];
---

<footer class="bg-primary text-white">
  <div class="container mx-auto px-4 py-12">
    <div class="grid gap-8 lg:grid-cols-[3fr_1fr_1fr]">
      <div>
        <Image src={logo} alt="Volta Capital" class="h-14 w-auto" />
        <p class="mt-4 text-base lg:text-lg text-white/80 lg:max-w-2xl">
          {dictionary.footer.tagline}
        </p>
        <div class="mt-4 text-base lg:text-lg">
          <p class="font-semibold">{dictionary.footer.companiesTitle}</p>
          <div class="underline">
            <p class="mt-2">
              <a
                href="https://regulus.com.mx/"
                target="_blank"
                rel="noreferrer"
                class="text-white/80"
              >
                Regulus
              </a>
            </p>
            <p>
              <a
                href="https://www.sujio.mx/"
                target="_blank"
                rel="noreferrer"
                class="text-white/80"
              >
                Sujio
              </a>
            </p>
            <p>
              <a
                href="https://www.hhgm.mx/"
                target="_blank"
                rel="noreferrer"
                class="text-white/80"
              >
                HHGM
              </a>
            </p>
          </div>
        </div>
      </div>
      <div class="underline">
        <p class="text-base lg:text-lg font-semibold">
          {dictionary.footer.navigationTitle}
        </p>
        <ul class="mt-3 space-y-2 text-base lg:text-lg text-white/80">
          {
            routeKeys.map((key) => (
              <li>
                <a
                  href={getRoute(locale, key)}
                  class="hover:text-white transition-colors"
                >
                  {dictionary.header.nav[key]}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="underline">
        <p class="text-base lg:text-lg font-semibold">
          {dictionary.footer.contactTitle}
        </p>
        <ul
          class="mt-3 space-y-2 text-base lg:text-lg text-white/80 [&_a:hover]:underline"
        >
          <li><a href="mailto:info@volta.capital">info@volta.capital</a></li>
          <li>
            <a href="mailto:contacto@regulus.com.mx">contacto@regulus.com.mx</a>
          </li>
          <li><a href="mailto:contacto@sujio.mx">contacto@sujio.mx</a></li>
        </ul>
      </div>
    </div>
    <div
      class="mt-10 border-t border-white/40 pt-6 text-center text-lg text-white/70"
    >
      {dictionary.footer.rights}
    </div>
  </div>
</footer>
