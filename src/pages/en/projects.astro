---
import Layout from "../../layout/Layout.astro";
import ProjectsSection from "@components/home/ProjectsSection.astro";
import ContactCta from "@components/home/ContactCta.astro";
import { getRoute } from "@i18n/routes";
import { ui } from "@i18n/ui";

const locale = "en";
const copy = ui[locale];
---

<Layout locale={locale} title={copy.projects.metaTitle}>
  <ProjectsSection {...copy.projects} />
  <ContactCta
    title={copy.cta.defaultTitle}
    button={copy.cta.defaultButton}
    href={getRoute(locale, "contact")}
  />
</Layout>
