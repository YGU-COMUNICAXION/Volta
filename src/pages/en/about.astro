---
import Layout from "../../layout/Layout.astro";
import AboutHero from "@components/about/AboutHero.astro";
import AboutStrengths from "@components/about/AboutStrengths.astro";
import AboutCompanies from "@components/about/AboutCompanies.astro";
import AboutClients from "@components/about/AboutClients.astro";
import AboutEvents from "@components/about/AboutEvents.astro";
import ContactCta from "@components/home/ContactCta.astro";
import { getRoute } from "@i18n/routes";
import { ui } from "@i18n/ui";

import heroImage from "@assets/img/about-us/bgBanner.jpg";
import parallaxImage from "@assets/img/about-us/parallax.jpg";
import presenceImage01 from "@assets/img/about-us/presencia/1.jpg";
import presenceImage02 from "@assets/img/about-us/presencia/02.jpg";
import presenceImage03 from "@assets/img/about-us/presencia/03.jpg";
import presenceImage04 from "@assets/img/about-us/presencia/04.jpg";
import placeholderImage from "@assets/img/about-us/placeholder.jpg";
import logoRegulus from "@assets/img/about-us/logoRegulus.png";
import logoSujio from "@assets/img/about-us/logoSujio.png";
import logoHHGM from "@assets/img/about-us/logoHHGM.png";
import logoSujioGeneration from "@assets/img/about-us/logoSujioGeneration.png";
import regularusCardImage from "@assets/img/about-us/RegulusEnergiaCard.jpg";
import sujioCardImage from "@assets/img/about-us/SujioCard.jpg";
import hhgmCardImage from "@assets/img/about-us/HHGMCard.jpg";
import sujioGenerationCardImage from "@assets/img/about-us/SujioGenerationCard.jpg";
import trendIcon from "@assets/svg/about-us/trend-up.svg";
import factoryIcon from "@assets/svg/about-us/icon_factory.svg";
import carIcon from "@assets/svg/about-us/icon_car.svg";
import buildingsIcon from "@assets/svg/about-us/icon_buildings.svg";

const locale = "en";
const copy = ui[locale];
const companyAssets = [
  { logo: logoRegulus, cardImage: regularusCardImage },
  { logo: logoSujio, cardImage: sujioCardImage },
  { logo: logoSujioGeneration, cardImage: sujioGenerationCardImage },
  { logo: logoHHGM, cardImage: hhgmCardImage },
];
const companies = copy.about.companies.map((company, index) => ({
  ...company,
  ...companyAssets[index],
}));
const clientIcons = [factoryIcon, carIcon, factoryIcon, factoryIcon, buildingsIcon];
const clientSegments = copy.about.clientSegments.map((segment, index) => ({
  ...segment,
  icon: clientIcons[index],
}));
const presenceImages = [
  presenceImage01,
  presenceImage02,
  presenceImage03,
  presenceImage04,
];
---

<Layout locale={locale} title={copy.about.metaTitle}>
  <AboutHero {...copy.about.hero} image={heroImage} />
  <AboutStrengths
    items={copy.about.strengths}
    icon={trendIcon}
    backgroundImage={parallaxImage}
    backgroundAlt={copy.about.hero.imageAlt}
    textLines={copy.about.strategyLines}
  />
  <AboutCompanies
    title={copy.about.companiesHeading}
    description={copy.about.companiesDescription}
    companies={companies}
    placeholderImage={placeholderImage}
  />
  <AboutClients title={copy.about.clientsTitle} segments={clientSegments} />
  <AboutEvents
    title={copy.about.eventsTitle}
    events={copy.about.events}
    images={presenceImages}
    imageAlt={copy.about.eventImageAlt}
    prevLabel={copy.about.eventPrevLabel}
    nextLabel={copy.about.eventNextLabel}
  />
  <ContactCta {...copy.about.cta} href={getRoute(locale, "contact")} />
</Layout>
