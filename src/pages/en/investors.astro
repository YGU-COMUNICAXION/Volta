---
import Layout from "../../layout/Layout.astro";
import InvestorsIntro from "@components/inversionistas/InvestorsIntro.astro";
import InvestorsWhy from "@components/inversionistas/InvestorsWhy.astro";
import ContactCta from "@components/home/ContactCta.astro";
import { getRoute } from "@i18n/routes";
import { ui } from "@i18n/ui";

const locale = "en";
const copy = ui[locale];
---

<Layout
  locale={locale}
  title={copy.investors.metaTitle}
  description={copy.investors.metaDescription}
>
  <InvestorsIntro {...copy.investors.firstSection} />
  <InvestorsWhy {...copy.investors.secondSection} />
  <ContactCta {...copy.investors.cta} href={getRoute(locale, "contact")} />
</Layout>
