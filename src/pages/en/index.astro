---
import Layout from "../../layout/Layout.astro";
import Hero from "@components/home/Hero.astro";
import Highlight from "@components/home/Highlight.astro";
import Approach from "@components/home/Approach.astro";
import CompaniesSection from "@components/home/CompaniesSection";
import Differentiators from "@components/home/Differentiators.astro";
import Stats from "@components/home/Stats.astro";
import CertificationsCarousel from "@components/home/CertificationsCarousel";
import HomeContact from "@components/home/HomeContact.astro";
import { ui } from "@i18n/ui";

const locale = "en";
const copy = ui[locale];
---

<Layout locale={locale}>
  <Hero {...copy.home.hero} />
  <Highlight {...copy.home.highlight} />
  <Approach {...copy.home.approach} />
  <CompaniesSection client:load {...copy.home.companies} />
  <Differentiators {...copy.home.differentiators} />
  <Stats {...copy.home.stats} />
  <CertificationsCarousel client:load {...copy.home.certifications} />
  <HomeContact {...copy.home.contact} />
</Layout>
